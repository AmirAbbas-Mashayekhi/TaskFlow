# Force everything to LF
* text=auto eol=lf

# Shell scripts must NEVER have CRLF
*.sh text eol=lf

# Docker / entrypoints / scripts
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Config files (important for dev environments)
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Explicit binaries (never touched)
*.png binary
*.jpg binary
*.exe binary